# Admin Portal Local Environment Variables
NODE_ENV=development
 
# Core API Connections
NEXT_PUBLIC_API_URL=http://localhost:8000/api/
NEXT_PUBLIC_API_URL_FALLBACK=http://localhost:8000/api/
NEXT_PUBLIC_WS_HOST=localhost
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/admin/health/
NEXT_PUBLIC_WS_TELEMETRY_URL_TEMPLATE=ws://localhost:8000/ws/telemetry/{tenant_id}/
 
# Dynamic Configs
NEXT_PUBLIC_COMPANY_PORTAL_BASE_URL=.localhost:3000
NEXT_PUBLIC_COMPANY_PORTAL_PROTOCOL=http
NEXT_PUBLIC_DEV_DOMAINS=localhost,127.0.0.1