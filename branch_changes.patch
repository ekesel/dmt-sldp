+      expect(screen.getByPlaceholderText(/QUICK SEARCH.../i)).toHaveValue('');
+    });
+
+    it('calls onNewRecord when the New Record button is clicked', () => {
+      // ARRANGE
+      const props = createMockProps();
+      render(<KnowledgeHeader {...props} />);
